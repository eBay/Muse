{
  "name": "@ebay/muse-lib-antd",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebay/Muse",
    "directory": "ui-plugins/muse-lib-antd"
  },
  "version": "1.3.5",
  "type": "module",
  "muse": {
    "type": "lib",
    "devConfig": {
      "app": "musemanager",
      "env": "staging"
    }
  },
  "files": [
    "build",
    "src",
    "MUSE_README.md"
  ],
  "scripts": {
    "start": "cross-env NODE_PATH=./node_modules NODE_ENV=development vite build --mode development --watch",
    "build": "cross-env NODE_PATH=./node_modules vite build",
    "build:dev": "cross-env NODE_ENV=development vite build --mode development",
    "build:test": "cross-env MUSE_TEST_BUILD=true vite build --mode e2e-test",
    "deploy": "pnpm build && pnpm build:dev && muse release && muse deploy nateapp staging",
    "postbuild": "cp MUSE_README.md ./build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@ebay/muse-core": "^1.0.45",
    "@ebay/muse-vite-plugin": "^1.0.56",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "less": "^4.6.4",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@ant-design/icons": "6.2.2",
    "@ebay/muse-lib-react": "1.3.5",
    "@ebay/nice-form-react": "2.0.3",
    "antd": "6.3.7",
    "history": "5.3.0",
    "js-plugin": "1.1.0",
    "lodash": "4.18.1",
    "moment": "2.30.1",
    "prop-types": "15.8.1",
    "react-copy-to-clipboard": "5.1.1",
    "react-highlight-words": "0.21.0",
    "react-syntax-highlighter": "16.1.1"
  },
  "pnpm": {}
}
