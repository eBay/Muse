{
  "name": "@ebay/muse-layout-antd",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebay/Muse",
    "directory": "ui-plugins/muse-layout-antd"
  },
  "version": "1.3.5",
  "type": "module",
  "muse": {
    "devConfig": {
      "app": "musemanager",
      "env": "staging"
    }
  },
  "files": [
    "build",
    "MUSE_README.md"
  ],
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:dev": "cross-env NODE_ENV=development vite build --mode development",
    "build:test": "cross-env MUSE_TEST_BUILD=true NODE_ENV=production vite build --mode e2e-test",
    "gen-muse-doc": "typedoc",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "postbuild": "cp MUSE_README.md ./build"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@ebay/muse-core": "^2.0.0",
    "@ebay/muse-lib-antd": "2.0.0",
    "@ebay/muse-lib-react": "2.0.0",
    "@ebay/muse-typedoc-plugin": "^1.0.6",
    "@ebay/muse-vite-plugin": "^2.0.0",
    "@eslint/js": "^10.0.1",
    "@jridgewell/gen-mapping": "^0.3.13",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^4.1.5",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jest-canvas-mock": "^2.5.2",
    "js-plugin": "1.1.0",
    "jsdom": "^29.1.1",
    "less": "^4.6.4",
    "lodash": "4.18.1",
    "react": "19.2.6",
    "react-redux": "9.2.0",
    "semver": "7.7.4",
    "tailwindcss": "^4.2.4",
    "typedoc": "^0.28.19",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "react-dom": "19.2.6"
  }
}
