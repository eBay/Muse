{
  "name": "@ebay/muse-manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/ebay/Muse",
    "directory": "ui-plugins/muse-manager"
  },
  "version": "1.3.6",
  "private": false,
  "type": "module",
  "muse": {
    "devConfig": {
      "app": "musemanager",
      "env": "staging",
      "remotePlugins": "*",
      "appOverride": {
        "noSSO": false,
        "variables": {
          "museApiEndpoint": "http://localhost:6080/api/v2"
        }
      }
    }
  },
  "files": [
    "build",
    "MUSE_README.md"
  ],
  "devDependencies": {
    "@ebay/muse-client": "^1.0.27",
    "@ebay/muse-core": "^2.0.0",
    "@ebay/muse-dev-utils": "^2.0.0",
    "@ebay/muse-express-middleware": "^2.0.0",
    "@ebay/muse-lib-antd": "^2.0.0",
    "@ebay/muse-lib-react": "^2.0.0",
    "@ebay/muse-plugin-acl": "^1.0.20",
    "@ebay/muse-vite-plugin": "^2.0.0",
    "@tanstack/react-query": "^5.100.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "cross-env": "^10.1.0",
    "find-root": "^1.1.0",
    "flat": "^6.0.1",
    "javascript-time-ago": "^2.6.4",
    "less": "^4.6.4",
    "lodash": "^4.18.1",
    "postcss": "^8.5.14",
    "pretty-ms": "^9.3.0",
    "react-color": "^2.19.3",
    "react-markdown": "^10.1.0",
    "react-time-ago": "^7.4.4",
    "semver": "^7.7.4",
    "tailwindcss": "^4.2.4",
    "util": "^0.12.5",
    "validate-npm-package-name": "^7.0.2",
    "vite": "^8.0.11",
    "web-vitals": "^5.2.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "build:dev": "cross-env NODE_ENV=development vite build --mode development",
    "build:test": "cross-env MUSE_TEST_BUILD=true NODE_ENV=production vite build --mode e2e-test",
    "deploy": "pnpm build && pnpm build:dev && muse release && muse deploy musemanager staging",
    "test": "react-scripts test",
    "postbuild": "cp MUSE_README.md ./build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "jsx-a11y/anchor-is-valid": 0
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4"
  }
}
